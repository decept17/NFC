----------------------------------------------------------------------

Core Application Configuration

----------------------------------------------------------------------

NODE_ENV=development
API_PORT=8080
JWT_SECRET=YOUR_LONG_RANDOM_STRING_FOR_AUTH_TOKENS
ENCRYPTION_KEY_AES=YOUR_32_BYTE_SECRET_FOR_SENSITIVE_DATA_ENCRYPTION

----------------------------------------------------------------------

Third-Party Payment Gateway (CRITICAL)

Must be sandbox keys initially. Example using generic Stripe/Adyen names.

----------------------------------------------------------------------

PAYMENT_GATEWAY_VENDOR=Stripe # e.g., Stripe, Adyen, WorldPay
PAYMENT_GATEWAY_SECRET_KEY=sk_test_YOUR_SANDBOX_SECRET
PAYMENT_GATEWAY_PUBLIC_KEY=pk_test_YOUR_SANDBOX_PUBLIC

----------------------------------------------------------------------

Database Connection (PostgreSQL - Used by Docker Compose)

Values must match those in docker-compose.yml for local development

----------------------------------------------------------------------

DB_HOST=db
DB_PORT=5432
DB_USER=nfcuser
DB_PASSWORD=nfcpassword
DB_NAME=nfc_db

----------------------------------------------------------------------

External Services (Email/SMS for alerts - optional for Sprint 1)

----------------------------------------------------------------------

SMS_SERVICE_API_KEY=
EMAIL_SERVICE_API_KEY=